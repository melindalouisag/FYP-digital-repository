SPRING_PROFILES_ACTIVE=aad
APP_AUTH_MODE=SSO
APP_UI_BASE_URL=http://localhost:5173

AZURE_TENANT_ID=__FILL_ME__
AZURE_CLIENT_ID=__FILL_ME__
AZURE_CLIENT_SECRET=__FILL_ME__

# Required storage backend
FILE_STORAGE_PROVIDER=azure
AZURE_STORAGE_ACCOUNT=__FILL_ME__
AZURE_STORAGE_KEY=__FILL_ME__
AZURE_STORAGE_CONTAINER=__FILL_ME__
AZURE_STORAGE_PREFIX=documents

# Optional alternative to account+key:
# AZURE_STORAGE_CONNECTION_STRING=__FILL_ME__

# Optional SMTP (not required)
# MAIL_HOST=__FILL_ME__
# MAIL_PORT=587
# MAIL_USERNAME=__FILL_ME__
# MAIL_PASSWORD=__FILL_ME__
# MAIL_FROM=no-reply@example.com
